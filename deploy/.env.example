# Copy to ".env" and adjust. These are read by server.py at startup.
# (Useful for LAN / self-host runs and Docker.)

# Require this password to access Kadmu (strongly recommended with --lan).
KADMU_PASSWORD=Apple123

# Port to listen on (default 8000).
KADMU_PORT=8000

# Set to 1 for a read-only / kiosk instance (disables all file management).
# KADMU_READONLY=1

# Comma-separated extra hostnames/domains allowed in the Host header,
# e.g. a reverse-proxy domain or a fixed LAN IP.
# KADMU_ALLOWED_HOSTS=kadmu.local,192.168.1.20

# --- Public-hardening & ops (Phase 3) ---------------------------------------

# Built-in HTTPS: serve TLS directly with this cert + key (PEM). For public
# exposure a reverse proxy (deploy/Caddyfile) is recommended instead.
# KADMU_TLS_CERT=/path/to/cert.pem
# KADMU_TLS_KEY=/path/to/key.pem

# Per-IP request rate limiting (loopback always exempt). On by default.
# KADMU_RATE_LIMIT=0      # disable
# KADMU_RATE_RPS=50       # sustained requests/sec per IP
# KADMU_RATE_BURST=200    # burst bucket size

# Cap simultaneous live transcode/remux streams per user (accounts) / per IP.
# KADMU_USER_MAX_STREAMS=3

# Structured per-request logging (JSON lines). Off by default.
# KADMU_LOG_REQUESTS=1
# KADMU_ACCESS_LOG=/var/log/kadmu/access.log   # default: stdout

# Idle-request socket timeout in seconds (slow-loris backstop, default 120).
# KADMU_REQUEST_TIMEOUT=120
