# Copy to ".env" and adjust. These are read by server.py at startup.
# (Useful for LAN / self-host runs and Docker.)

# Require this password to access Kinema (strongly recommended with --lan).
KINEMA_PASSWORD=change-me

# Port to listen on (default 8000).
KINEMA_PORT=8000

# Set to 1 for a read-only / kiosk instance (disables all file management).
# KINEMA_READONLY=1

# Comma-separated extra hostnames/domains allowed in the Host header,
# e.g. a reverse-proxy domain or a fixed LAN IP.
# KINEMA_ALLOWED_HOSTS=kinema.local,192.168.1.20
