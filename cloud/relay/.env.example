# ============================================================================
# Kadmu Cloud — relay (coturn) environment.
# ----------------------------------------------------------------------------
# Copy to `.env` (same directory). docker-compose.yml reads it; the relay
# container's entrypoint substitutes the $(VAR) placeholders in turnserver.conf.
#
#   cp cloud/relay/.env.example cloud/relay/.env
#   # then edit the blanks below and `docker compose up -d`
#
# NEVER commit your real `.env`. Only this `.example` is tracked.
# See docs/PHASE_5_DESIGN.md §2 and cloud/relay/README.md.
# ============================================================================

# --- TURN credential scheme (must match the control-plane) ------------------
# Shared HMAC-SHA1 secret for the TURN REST API ephemeral-credential scheme.
# coturn validates minted credentials against this with NO callback to us.
# The SAME value must be configured on the control-plane (4a) so the credentials
# it mints validate here. Generate once:
#     openssl rand -hex 32
# Keep it secret; rotating it invalidates all outstanding credentials (they're
# short-TTL anyway, so rotation is cheap).
TURN_SECRET=

# Authentication realm — also the public hostname of this relay. Clients see it,
# and it's bound into credential hashing. Point a DNS A record at this VPS.
TURN_REALM=turn.kadmu.app

# Public IPv4 of this VPS, advertised in relay candidates. REQUIRED on a NAT'd
# VPS (most cloud VPSes are 1:1 NAT). For 1:1 NAT you may use <public>/<private>.
# Leave blank only if coturn can auto-detect a directly-bound public IP.
TURN_EXTERNAL_IP=

# --- Relay (media) UDP port range -------------------------------------------
# One relay port is allocated per session, so this window caps concurrency.
# Must match min-port/max-port in turnserver.conf AND the firewall + the ports
# published in docker-compose.yml. Widen for more concurrent relayed sessions.
RELAY_MIN_PORT=49160
RELAY_MAX_PORT=49200

# --- Metering collector (cloud/metering/collector.py) -----------------------
# Where the collector scrapes coturn's Prometheus exporter. With host networking
# this is loopback on the relay box. The collector diffs the byte counters and
# attributes them per tenant (Phase 5 §2.3).
COTURN_METRICS_URL=http://127.0.0.1:9641/metrics

# Path to the shared control-plane SQLite DB the collector writes relay usage to.
# This SHOULD be the same cloud.db the control-plane reads for cap decisions
# (one store, one Litestream backup — design §2.2 / §10.2). Inside the
# meter-collector container this is the mounted data volume path.
KADMU_METER_DB=/data/cloud.db
