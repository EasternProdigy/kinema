# Kadmu Cloud infra (Phase 5) — environment for docker-compose.scale.yml.
# Copy to `.env` (same dir) and fill in. NOTHING here is committed with a real value.
#   docker compose -f cloud/infra/docker-compose.scale.yml --env-file cloud/infra/.env up -d
#
# The control-plane reads its own Stripe/licensing vars too — this file is the union,
# so a single `--env-file` feeds every service. See cloud/control-plane/.env.example
# for the Stripe-specific keys (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_*).

# ─────────────── signaling brokers (sig1, sig2, …) ───────────────
# HMAC secret the broker uses to verify entitlement tokens minted by the control-plane.
# MUST be set in production — with it empty the broker runs in DEV mode (accepts ANY
# token), which would let anyone broker. Generate: `openssl rand -hex 32`.
KADMU_SIGNAL_SECRET=
# Lock CORS to the app-shell origin (the broker defaults to "*").
KADMU_SIGNAL_ORIGIN=https://app.kadmu.app
# Tunables (defaults shown). PEER_TTL: drop a peer unseen this long. POLL_TIMEOUT: how
# long a long-poll blocks before returning empty (must stay < Caddy's proxy read_timeout).
KADMU_SIGNAL_PEER_TTL=60
KADMU_SIGNAL_POLL_TIMEOUT=25

# ─────────────── control-plane (Stripe / licensing) ───────────────
# Leave STRIPE_SECRET_KEY blank to run the control-plane in MOCK mode (no real charges).
KADMU_CLOUD_BASE_URL=https://cloud.kadmu.app
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_MONTHLY=price_xxx
# STRIPE_PRICE_YEARLY=price_xxx
# KADMU_CLOUD_LICENSE_TTL=86400        # 24h license token TTL (recommended)
# KADMU_CLOUD_OFFLINE_GRACE=604800     # 7-day offline grace (recommended)

# ─────────────── coturn relay (separate VPS) ───────────────
# The relay runs from cloud/relay/docker-compose.yml on its OWN box. Prometheus here
# scrapes its exporter across the network — set its reachable host:port (the coturn
# Prometheus exporter listens on :9641 by default).
RELAY_HOST=relay.kadmu.app:9641
# Shared secret coturn uses for REST-API ephemeral credentials (use-auth-secret).
# Same value the control-plane signs relay creds with. Generate: `openssl rand -hex 32`.
KADMU_TURN_SECRET=

# ─────────────── core app-shell origin (behind the CDN) ───────────────
# The core node serving the static app shell + /api in CDN/origin mode (KADMU_CDN=1).
# Used by the Caddy `app.kadmu.app` vhost as `app-origin:8000` and as a Prometheus
# scrape target (its Phase-3 /metrics). Adjust host:port to your origin node.
CORE_NODE_HOST=app-origin:8000

# ─────────────── observability ───────────────
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=https://grafana.kadmu.app

# ─────────────── fleet relay budget (the money alert) ───────────────
# Global monthly relay-egress backstop in BYTES, used by alerts.yml's
# RelayEgressOverBudget (a fleet ceiling ABOVE the per-tenant caps). Note: this value
# is referenced in the alert expression's comment; Prometheus alert thresholds are
# baked into alerts.yml (PromQL has no env interpolation) — keep the two in sync.
# Example: 2 TiB/month ≈ 2199023255552.
RELAY_FLEET_BUDGET_BYTES=2199023255552
