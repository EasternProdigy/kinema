    {
      "type": "timeseries",
      "title": "Aggregate relay egress vs. monthly budget (~30d)",
      "description": "sum(increase(kadmu_relay_bytes_total[30d])) against the 2 TiB fleet budget line. The backstop above per-tenant caps — see alerts.yml RelayEgressOverBudget.",
