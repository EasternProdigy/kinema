      },
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "kadmu-prometheus" },
          "expr": "sum(increase(kadmu_relay_bytes_total[30d]))",
          "legendFormat": "Relay egress (30d)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "kadmu-prometheus" },
