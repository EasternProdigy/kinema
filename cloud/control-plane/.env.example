# Kadmu Cloud control-plane — environment.
# Copy to `.env` and `export $(grep -v '^#' .env | xargs)` before launching, or set
# these in your process manager. EVERYTHING is optional: with no STRIPE_SECRET_KEY the
# control-plane runs in MOCK mode (no real charges) so the whole funnel works locally.

# --- Network -------------------------------------------------------------------
KADMU_CLOUD_HOST=127.0.0.1
KADMU_CLOUD_PORT=8787
# Public origin used to build Stripe redirect + dashboard links. Behind a reverse
# proxy in production this is your https:// origin (e.g. https://cloud.kadmu.app).
KADMU_CLOUD_BASE_URL=http://127.0.0.1:8787
# Where the SQLite DB lives (defaults to cloud/control-plane/data/).
# KADMU_CLOUD_DATA=/var/lib/kadmu-cloud

# --- Mode ----------------------------------------------------------------------
# auto (default): MOCK unless STRIPE_SECRET_KEY is set. Force with mock|live.
# KADMU_CLOUD_MODE=mock

# --- Stripe (leave blank for MOCK mode) ----------------------------------------
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx          # from the Stripe webhook endpoint config
# Recurring Price IDs you created in the Stripe dashboard (mode=subscription):
# STRIPE_PRICE_MONTHLY=price_xxx
# STRIPE_PRICE_YEARLY=price_xxx

# --- Licensing tunables (sensible defaults; rarely need changing) ---------------
# KADMU_CLOUD_LICENSE_TTL=86400            # issued license validity (seconds)
# KADMU_CLOUD_OFFLINE_GRACE=604800         # node grace past expiry when cloud unreachable

# When live: point your Stripe webhook at  <BASE_URL>/api/webhook/stripe  and send
#   checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed
